# Voicer Desktop Host — Local Environment
# BYOK API keys live here, NEVER in the cloud database.

# Unified voice brain (Gemini 2.5 Flash Live API)
GEMINI_API_KEY=

# Supabase (for WebRTC signaling)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
USER_ID=

# Cloudflare TURN (for 4G / mobile connections)
# Create a key at: dash.cloudflare.com > Realtime > TURN
CF_TURN_KEY_ID=
CF_TURN_API_TOKEN=

# Host config
HOST_PORT=8000
