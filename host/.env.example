# Voicer Desktop Host — Local Environment
# BYOK API keys live here, NEVER in the cloud database.

# Voice STT (Deepgram)
DEEPGRAM_API_KEY=

# AI Providers (BYOK — user's own keys)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# TTS (local Kokoro or OpenAI)
TTS_PROVIDER=kokoro  # Options: kokoro, openai
OPENAI_TTS_API_KEY=

# Host config
HOST_PORT=8000
